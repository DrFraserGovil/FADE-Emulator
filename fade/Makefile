#Auto-generated by the projectmake utility
BUILD_DIR = .build

.PHONY: all clean purge

# 1. The default target: ensures .build exists, runs cmake, then builds
all:
	@mkdir -p $(BUILD_DIR)
	@cmake -S . -B $(BUILD_DIR)
	@make -C $(BUILD_DIR) --no-print-directory

purge:
	@rm -rf $(BUILD_DIR)
	@rm -f cortex cortex_test

clean:
	@make purge
	@make all --no-print-directory
